MONGO_URI=mongodb://localhost:27017/on_demand_service
JWT_SECRET=your_jwt_secret
PORT=3000
NODE_ENV=development

# Upload storage (Render persistent disk recommended)
# UPLOADS_DIR=/var/data/uploads

# Cloudinary (recommended if you don't have a persistent disk)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Firebase Cloud Messaging (push)
# FIREBASE_SERVICE_ACCOUNT_JSON=base64:...
